# Copy to `.env.local` (or `.env`) and fill values. Never commit real secrets.

# Neon / PostgreSQL connection string (sslmode=require recommended)
#
# Performance tip — use the POOLED endpoint for serverless / dev. The pooled
# endpoint contains "-pooler" in the host. Direct (non-pooled) connections
# add 200–800ms of TCP+TLS+auth on every cold start. Example:
#
#   postgresql://USER:PASSWORD@ep-xyz-pooler.REGION.aws.neon.tech/dbname?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST/dbname?sslmode=require"

# Public site URL (required for metadata / canonical URLs — no trailing slash)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Gmail (quotation / transactional mail) — preferred when both are set
# Create an App Password: https://support.google.com/accounts/answer/185833
GMAIL_USER=
GMAIL_APP_PASSWORD=

# From address for transactional mail (required when using Resend; recommended for Gmail)
# Example: "Quotations <you@gmail.com>"
QUOTATION_EMAIL_FROM=

# Resend (optional fallback if Gmail is not configured) — https://resend.com
RESEND_API_KEY=
